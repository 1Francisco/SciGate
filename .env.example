# ============================================================
# SciGate — Frontend (Next.js) environment variables
# Copy to .env.local for local dev.
# ============================================================

# ── Demo mode ────────────────────────────────────────────────
# Set to "true" for live demo / local dev. Enables:
#   - Manual wallet fallback UI
#   - Mock payment bypass with x-payment-proof: demo_bypass
# NEVER set to "true" in production.
NEXT_PUBLIC_DEMO_MODE=false

# ── Backend URLs ─────────────────────────────────────────────
# Public URL of the Hono x402 gateway (Fase 3: llamado directo, sin proxy Next)
NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:3001
# Public URL of the RAG engine (used only for direct uploads from browser)
NEXT_PUBLIC_RAG_URL=http://127.0.0.1:8000

# ── World ID ─────────────────────────────────────────────────
# Production App ID from developer.world.org
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_ACTION_ID=verify-author

# ── Payments ─────────────────────────────────────────────────
# Wallet address to receive royalties (global default; per-paper authors override this)
NEXT_PUBLIC_PAY_TO_ADDRESS=

# ── On-chain registry ────────────────────────────────────────
# PaperRegistry deployed address (World Chain Sepolia 4801 or Mainnet 480)
# Leave empty until a real deploy exists — the app will refuse to register on-chain.
NEXT_PUBLIC_PAPER_REGISTRY_ADDRESS=
