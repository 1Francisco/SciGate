# ============================================================
# SciGate — x402 Gateway (Hono) environment variables
# ============================================================

# ── Demo mode (MUST be "false" in production) ────────────────
DEMO_MODE=false

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Payments ──────────────────────────────────────────────────
# Global fallback payee wallet. Per-paper authors override this.
PAY_TO_ADDRESS=
PAY_TO_ADDRESS_SOLANA=

# ── Blockchain (World Chain) ──────────────────────────────────
WORLD_CHAIN_RPC=https://rpc.worldchain.dev
PAPER_REGISTRY_ADDRESS=
# Private key used to call recordAccess() on-chain after a paid access.
# Use a hot wallet with limited funds. Rotate periodically.
RECORDER_PRIVATE_KEY=

# ── World ID ──────────────────────────────────────────────────
WORLD_APP_ID=
WORLD_ACTION_ID=verify-author
# Required for production Mainnet (RP context / native signing)
WORLD_ID_RP_ID=
WORLD_ID_SIGNING_KEY=

# ── RAG engine ────────────────────────────────────────────────
RAG_SERVICE_URL=http://127.0.0.1:8000
# Shared secret for server→RAG internal calls. Must match RAG_INTERNAL_TOKEN in the RAG service.
RAG_INTERNAL_TOKEN=

# ── Supabase (server uses SERVICE_ROLE, not ANON) ─────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Observability ─────────────────────────────────────────────
# Token required to POST /debug/log. If empty, endpoint is disabled.
DEBUG_LOG_TOKEN=

# ── Rate limiting (optional) ──────────────────────────────────
RATE_LIMIT_RPM=20
